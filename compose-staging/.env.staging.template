# Staging environment variables — KHÔNG commit secrets thật
# Copy này → .env.staging trên VM, điền giá trị production-grade

# === Database (csr-data VM 10.10.1.11) ===
POSTGRES_PASSWORD=<production-grade-password>
POSTGRES_DB=medusa
POSTGRES_USER=postgres

# === Redis ===
REDIS_PASSWORD=<production-grade-password>

# === MinIO (csr-storage VM 10.10.1.12) ===
MINIO_ROOT_USER=<production-user>
MINIO_ROOT_PASSWORD=<production-grade-password>

# === Meilisearch (csr-storage) ===
MEILI_MASTER_KEY=<production-grade-key-32chars>

# === Medusa (csr-app VM 10.10.1.10) ===
