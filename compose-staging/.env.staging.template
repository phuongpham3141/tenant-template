# === Payload CMS ===
PAYLOAD_SECRET=<random-32-char-string>
PAYLOAD_PUBLIC_SERVER_URL=https://cms.staging.cybersilkroads.vn

# === Tenant ===
TENANT_ID=cybersilkroads
