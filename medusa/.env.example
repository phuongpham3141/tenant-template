# =====================================================================
# Medusa v2 environment variables — tenant template HUAYUE Platform
# =====================================================================
#
# Copy file này thành `.env` và điền giá trị thực tế cho mỗi environment.
# KHÔNG commit `.env` (đã có trong .gitignore).
#
# Tenant canonical: 'csr' (Sprint 1 R20 design, Sprint 9B Pha 1d-a v2 REVERT confirmed)
# Reference: CONVENTIONS.md + docs/sprint-roadmap.md
# =====================================================================

# ===== Core Server =====
NODE_ENV=development
# development | staging | production

MEDUSA_WORKER_MODE=shared
# shared | worker | server (separation of concerns Sprint 10+ production)

# ===== Database =====
DATABASE_URL=postgres://postgres:devpass123@postgres:5432/medusa
# Production: postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

PG_POOL_MAX=20
# Default 10; tăng cho production

# ===== Redis =====
REDIS_URL=redis://redis:6379
# Production: redis://USER:PASSWORD@HOST:6379/0

# ===== Secrets (32+ chars random) =====
JWT_SECRET=dev-jwt-secret-change-in-production
COOKIE_SECRET=dev-cookie-secret-change-in-production

# ===== CORS =====
STORE_CORS=http://localhost:8000,http://shop.huayuesc.local
ADMIN_CORS=http://localhost:7001,http://admin.huayuesc.local
AUTH_CORS=http://localhost:8000,http://localhost:7001,http://shop.huayuesc.local,http://admin.huayuesc.local

# ===== Tenant Context =====
DEFAULT_TENANT_ID=csr
# Canonical tenant slug (Sprint 1 R20 design — D20-a EXPANDED REVERT)
SYSTEM_TENANT_ID=csr
# Jobs/subscribers fallback khi không có request context

# ===== Object Storage (MinIO-compatible S3) =====
S3_ENDPOINT=http://minio:9000
S3_BUCKET=medusa-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_FILE_URL=http://minio:9000/medusa-uploads
S3_PUBLIC_BASE=http://minio.huayuesc.local/medusa-uploads

# ===== Search (Elasticsearch — Sprint 1 R20) =====
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=dev-es-password

# ===== Media (HLS + MUX video) =====
HLS_PUBLIC_BASE=http://minio.huayuesc.local/hls
MUX_FIFO_ROOT=/tmp/mux-fifo
MUX_HLS_ROOT=/var/lib/medusa/hls
MUX_CONCURRENCY=2
# MUX_DEBUG=1  # uncomment để debug muxing pipeline

# ===== FX (currency conversion) =====
FX_API_URL=https://api.exchangerate.host/latest

# ===== Webhook tokens (Sprint 10+ CDC + cross-service) =====
# CDC_WEBHOOK_TOKEN=
# PAYLOAD_TO_MEDUSA_TOKEN=

# =====================================================================
# OPTIONAL — Sprint 10+ integrations
# =====================================================================

# ===== Email (SendGrid) =====
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=noreply@huayuesc.vn
# DPO_EMAIL=privacy@huayuesc.vn

# ===== AI Services =====
# OPENAI_API_KEY=
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
# ANTHROPIC_API_KEY=
# QWEN_API_KEY=
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# HEYGEN_API_KEY=
# DID_API_KEY=
# ELEVENLABS_API_KEY=
# ELEVENLABS_MODEL=eleven_multilingual_v2
# COQUI_TTS_URL=http://coqui-tts:5002

# AI Worker Concurrency
# AI_CHAT_CONCURRENCY=4
# AI_DIRECTOR_CONCURRENCY=2
# AI_TTS_CONCURRENCY=4
# AI_VIDEO_CONCURRENCY=2
# VISUAL_EMBED_CONCURRENCY=4

# ===== Payment Gateways =====

# Vietnamese: VNPay
# VNPAY_TMN_CODE=
# VNPAY_HASH_SECRET=
# VNPAY_API_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# VNPAY_RETURN_URL=http://shop.huayuesc.local/payment/vnpay/return

# Vietnamese: MoMo
# MOMO_PARTNER_CODE=
# MOMO_ACCESS_KEY=
# MOMO_SECRET_KEY=
# MOMO_API_URL=https://test-payment.momo.vn/v2/gateway/api/create
# MOMO_IPN_URL=http://api.huayuesc.local/store/payment/momo/ipn
# MOMO_RETURN_URL=http://shop.huayuesc.local/payment/momo/return

# Vietnamese: ZaloPay
# ZALOPAY_APP_ID=
# ZALOPAY_KEY=
# ZALOPAY_API_URL=https://sb-openapi.zalopay.vn/v2/create
# ZALOPAY_CALLBACK_URL=http://api.huayuesc.local/store/payment/zalopay/callback
# ZALOPAY_RETURN_URL=http://shop.huayuesc.local/payment/zalopay/return

# International: Stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# International: Alipay (cross-border)
# ALIPAY_APP_ID=
# ALIPAY_API_URL=https://openapi-sandbox.alipay.com/gateway.do

