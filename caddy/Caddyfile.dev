{
    auto_https off
}

http://shop.huayuesc.local {
    reverse_proxy storefront:3001
}

# Medusa Admin (v2: /app path on same port as API)
http://admin.huayuesc.local {
    redir / /app permanent
    reverse_proxy medusa-server:9000
}

http://api.huayuesc.local {
    reverse_proxy medusa-server:9000
}

http://cms.huayuesc.local {
    reverse_proxy payload-cms:3000
}

http://metrics.huayuesc.local {
    reverse_proxy grafana:3000
}

http://minio.huayuesc.local {
    reverse_proxy minio:9001
}
