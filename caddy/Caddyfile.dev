{
    auto_https off
}

# Reusable: dev-mode no-cache headers for storefront (and catch-all)
(no_cache_dev) {
    header /_next/* {
        Cache-Control "no-store, must-revalidate"
        -ETag
        -Last-Modified
    }
    header / {
        Cache-Control "no-store, must-revalidate"
    }
}

# === Storefront — multi-locale subdomains ============================
# `shop.` = default Vietnamese (vi locale)
# `en.`   = English locale
# `cn.`   = Chinese locale
# All proxy to the same Next.js storefront; locale is read from the
# request's `Host` header by middleware.ts and stored as cookie.

http://shop.huayuesc.local,
http://en.huayuesc.local,
http://cn.huayuesc.local,
http://vi.huayuesc.local {
    import no_cache_dev
    reverse_proxy storefront:3001
}

# Catch-all (raw IP, external domain, etc.) — also storefront (defaults to vi)
:80 {
    import no_cache_dev
    reverse_proxy storefront:3001
}

# Medusa Admin (v2: /app path on same port as API)
http://admin.huayuesc.local {
    redir / /app permanent
    reverse_proxy medusa-server:9000
}

http://api.huayuesc.local {
    reverse_proxy medusa-server:9000
}

http://cms.huayuesc.local {
    reverse_proxy payload-cms:3000
}

http://metrics.huayuesc.local {
    reverse_proxy grafana:3000
}

http://minio.huayuesc.local {
    reverse_proxy minio:9001
}
